DB_URL=jdbc:mysql://localhost:3306/ai_provider?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf-8
DB_USERNAME=ai_provider
DB_PASSWORD=replace-with-long-random-password
SERVER_PORT=8888
CCXT_GATEWAY_URL=http://127.0.0.1:8890
CCXT_GATEWAY_HOST=127.0.0.1
CCXT_GATEWAY_PORT=8890
CCXT_ALLOWED_EXCHANGES=okx,binance,bybit,kraken,coinbase,kucoin,bitget,gate,mexc
CCXT_EXCHANGE_TIMEOUT_MS=10000
CCXT_HTTPS_PROXY=
CRYPTO_MARKET_CONNECT_TIMEOUT_MS=3000
CRYPTO_MARKET_READ_TIMEOUT_MS=15000
FOUNDRY_RPC_URL=https://ethereum-rpc.publicnode.com
FOUNDRY_COMMAND_TIMEOUT_MS=10000
FOUNDRY_FORGE_COMMAND=/root/.foundry/bin/forge
FOUNDRY_CAST_COMMAND=/root/.foundry/bin/cast
FOUNDRY_ANVIL_COMMAND=/root/.foundry/bin/anvil
FOUNDRY_CHISEL_COMMAND=/root/.foundry/bin/chisel
MONITOR_TIMEZONE=Asia/Shanghai
MONITOR_DISK_PATH=.
MONITOR_DETAIL_RETENTION_DAYS=30
MONITOR_LOCAL_PROVIDER=TENCENT
TENCENT_MONITOR_SERVER_URL=http://124.222.185.195
TENCENT_MONITOR_PUBLIC_IP=124.222.185.195
AWS_MONTHLY_TRAFFIC_QUOTA_BYTES=100000000000
AWS_REGION=ap-northeast-1
AWS_INSTANCE_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TENCENT_CLOUD_SECRET_ID=replace-with-secret-id
TENCENT_CLOUD_SECRET_KEY=replace-with-secret-key
TENCENT_CLOUD_REGION=ap-shanghai
TENCENT_CLOUD_LIGHTHOUSE_INSTANCE_ID=lhins-20ht1gis
TWITTER_STORAGE_DIRECTORY=/opt/aimaid/twitter-media
# 生成方式: openssl rand -base64 32。修改此值会使已保存的 Twitter 登录会话失效。
TWITTER_SESSION_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
TWITTER_HEADLESS=true
TWITTER_NAVIGATION_TIMEOUT_MS=60000
TWITTER_BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
TWITTER_PUBLISH_MODE=client
# 仅供本地 Vite 开发代理使用；生产环境由 Nginx 转发 /api。
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8888
# Base64 encoded 32-byte AES key used only to encrypt Gemini credentials at rest.
CONTENT_AI_SECRET_ENCRYPTION_KEY=
