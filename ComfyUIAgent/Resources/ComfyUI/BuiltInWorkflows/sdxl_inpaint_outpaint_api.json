{
  "1": {
    "inputs": { "ckpt_name": "__AIPROVIDER_FIRST_CHECKPOINT__" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "SDXL 模型" }
  },
  "2": {
    "inputs": { "image": "input.png", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "遮罩原图" }
  },
  "3": {
    "inputs": { "text": "natural seamless continuation, detailed", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "正向提示词" }
  },
  "4": {
    "inputs": { "text": "low quality, blurry, artifacts, deformed", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "负向提示词" }
  },
  "5": {
    "inputs": { "pixels": ["2", 0], "vae": ["1", 2], "mask": ["2", 1], "grow_mask_by": 24 },
    "class_type": "VAEEncodeForInpaint",
    "_meta": { "title": "蒙版编码" }
  },
  "6": {
    "inputs": {
      "seed": 0,
      "steps": 28,
      "cfg": 6,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 0.65,
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "修补采样" }
  },
  "7": {
    "inputs": { "samples": ["6", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "修补解码" }
  },
  "8": {
    "inputs": { "filename_prefix": "AIProvider/inpaint", "images": ["7", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "最终修补结果" }
  }
}
